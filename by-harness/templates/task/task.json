{
  "project": "{{项目名称}}",
  "version": "1.0",
  "created": "{{YYYY-MM-DD}}",
  "updated": "{{YYYY-MM-DD}}",
  "methodology": "Effective harnesses for long-running agents (https://www.anthropic.com/engineering/effective-harnesses-for-long-running-agents)",
  "description": "{{项目描述}}",
  "status": "in_progress",

  "harness": {
    "initializer_done": true,
    "files": {
      "feature_list": "feature_list.json",
      "task_index": "task-harness/index.json",
      "feature_buckets": "task-harness/features/",
      "progress_shards": "task-harness/progress/",
      "handoff_shards": "task-harness/handoff/",
      "progress_log": "progress.txt",
      "init_script": "init.sh",
      "main_contract": "AGENTS.md",
      "task_contract": "TASK-HARNESS.md"
    },
    "rules": [
      "每个会话只做 1-2 个功能，不要贪多",
      "开始前先运行 bash init.sh 了解当前状态",
      "先读取 AGENTS.md（Harness 主闭环规则）",
      "再读取 TASK-HARNESS.md（任务层规则）",
      "读取 task-harness/progress/YYYY-MM.md（兼容入口 progress.txt）获取上次进度",
      "读取 task-harness/index.json 与 active bucket 文件定位下一个未完成功能",
      "必须执行 plan/build/qa，且 qa>=80 后才允许标记完成",
      "每个 feature 必须维护 spec_path/contract_path/qa_report_path",
      "完成后仅更新 active bucket 中对应 feature 的 passes 字段",
      "会话结束运行 scripts/session_close.py 生成 task-harness/handoff/*.md 与最新 HANDOFF.md",
      "每次完成功能后 git commit",
      "会话结束前写入 task-harness/progress/YYYY-MM.md（兼容指针写入 progress.txt）",
      "只修改 passes 字段，不要删除或编辑其他字段"
    ]
  },

  "milestones": [
